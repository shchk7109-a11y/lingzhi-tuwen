# =====================================================
# 灵芝内容生成系统 - 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值
# =====================================================

# 数据库连接（SQLite 文件路径）
DATABASE_URL="file:./prisma/dev.db"

# 应用访问 URL（用于 Puppeteer 内部访问封面渲染页面）
# 开发环境通常为 http://localhost:3000
# 生产环境填写实际域名，如 https://your-domain.com
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 管理员密码（优先级高于数据库中存储的密码）
# 首次部署时请修改此值，不要使用默认值
ADMIN_PASSWORD="your-strong-password-here"

# 备用默认密码（仅当 ADMIN_PASSWORD 和数据库均未设置时使用）
DEFAULT_ADMIN_PASSWORD="changeme"

# Puppeteer Chromium 可执行文件路径
# Linux (Ubuntu/Debian): /usr/bin/chromium-browser 或 /usr/bin/chromium
# macOS (Homebrew): /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROMIUM_PATH="/usr/bin/chromium-browser"

# 封面并发渲染数量（根据服务器内存调整，建议 2-5）
MAX_CONCURRENT_RENDERS="3"

# 浏览器空闲超时（毫秒），超时后关闭浏览器释放内存
BROWSER_IDLE_TIMEOUT_MS="300000"
