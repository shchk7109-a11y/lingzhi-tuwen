generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  nickname    String?
  gender      String?
  age         Int?
  occupation  String?
  city        String?
  income      String?
  category    String   @default("职场精英型")
  lifestyle   String?
  painPoints  String?
  needs       String?
  scenes      String?
  language    String?
  xhsAccount    String?
  wechatAccount String?
  wechatId      String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contents    Content[]

  // === Sprint 1 新增字段 ===
  accountId       String?
  platform        String?   @default("xiaohongshu")
  personaName     String?
  personaDesc     String?
  targetAudience  String?
  tier3Eligible   Boolean   @default(false)

  // === Sprint 1 新增关联 ===
  publishHabit       PublishHabit?
  contentPreference  ContentPreference?
  writingStyle       WritingStyle?
  trendTracking      TrendTracking?
  performanceMetric  PerformanceMetric?
  contentHistories   ContentHistory[]
}

model Material {
  id          String   @id @default(cuid())
  filename    String
  filepath    String
  webPath     String
  productLine String
  productName String
  sceneType   String   @default("场景图")
  tags        String?
  isFormula   Boolean  @default(false)
  isProduct   Boolean  @default(false)
  status      String   @default("active")
  createdAt   DateTime @default(now())

  // === Sprint 1 新增字段 ===
  updatedAt      DateTime  @updatedAt @default(now())
  sourceType     String    @default("manual")
  styleTags      Json?
  tierLevel      Int       @default(1)
  weeklyRefCount Int       @default(0)
  dailyRefCount  Int       @default(0)
  maxDailyRef    Int       @default(8)
  expiresAt      DateTime?
  colorTone      String?
  season         String?
  category       String?
}

model Prompt {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  content     String
  category    String   @default("general")
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Content {
  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  originalText    String
  cleanedText     String?
  coverData       String?
  coverUrl        String?
  title           String?
  subtitle        String?
  productName     String?
  productSlogan   String?
  coverStyle      String?
  matchedImage2   String?
  matchedImage3   String?
  image2Url       String?
  image3Url       String?
  image4Url       String?
  platform        String   @default("xhs")
  tags            String?
  xhsAccount      String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// === Sprint 1 新增模型 ===

model PublishHabit {
  id                 String   @id @default(uuid())
  customerId         String   @unique
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  preferredTimeSlots Json?
  dailyPostCount     Int      @default(3)
  imageTextRatio     Float    @default(0.7)
  contentLengthPref  String   @default("medium")
  hashtagStyle       String   @default("mixed")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ContentPreference {
  id                     String   @id @default(uuid())
  customerId             String   @unique
  customer               Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  preferredConstitutions Json?
  preferredProducts      Json?
  topicTags              Json?
  avoidTopics            Json?
  seasonalFocus          Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model WritingStyle {
  id               String   @id @default(uuid())
  customerId       String   @unique
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tone             String   @default("warm")
  catchphrases     Json?
  sentencePatterns Json?
  styleSamples     Json?
  emojiFrequency   String   @default("medium")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TrendTracking {
  id               String   @id @default(uuid())
  customerId       String   @unique
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  industryKeywords Json?
  seasonalTopics   Json?
  trendingResponse String   @default("moderate")
  externalFeeds    Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PerformanceMetric {
  id               String    @id @default(uuid())
  customerId       String    @unique
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  avgLikeRate      Float     @default(0)
  avgCommentRate   Float     @default(0)
  avgShareRate     Float     @default(0)
  bestContentTypes Json?
  bestPostTimes    Json?
  totalPosts       Int       @default(0)
  viralCount       Int       @default(0)
  lastCalculated   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ContentHistory {
  id                String    @id @default(uuid())
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  originalCopyId    String?
  cleanedCopy       String?   @db.Text
  imageUrls         Json?
  visualFingerprint Json?
  platform          String
  contentType       String
  productIds        Json?
  scheduledTime     DateTime?
  publishedAt       DateTime?
  status            String    @default("pending")
  hashtags          Json?
  engagement        Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([customerId])
  @@index([platform])
  @@index([contentType])
  @@index([status])
  @@index([publishedAt])
}
